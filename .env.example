# =============================================================================
# Sentinel Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.
# =============================================================================

# --- LLM Provider Selection ---
# Options: ollama, openai, anthropic, gemini, azure, bedrock, vertex,
#          ollama_structured, openai_compat, llamacpp, transformer_classifier, fallback
SHIELD_LLM_PROVIDER=ollama
SHIELD_LLM_MODEL=llama3

# --- Cloud LLM API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Azure OpenAI (if using azure provider) ---
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-02-01

# --- AWS Bedrock (if using bedrock provider) ---
# AWS_REGION=us-east-1

# --- Google Vertex AI (if using vertex provider) ---
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_REGION=us-central1

# --- OpenAI-Compatible Server (vLLM, LocalAI, LM Studio) ---
# SHIELD_OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
# SHIELD_OPENAI_COMPAT_API_KEY=not-needed

# --- llama-cpp-python (if using llamacpp provider) ---
# SHIELD_GGUF_PATH=/path/to/model.gguf
# SHIELD_GPU_LAYERS=0

# --- Transformer Classifier (if using transformer_classifier provider) ---
# SHIELD_CLASSIFIER_MODEL=protectai/deberta-v3-base-prompt-injection-v2
# SHIELD_CLASSIFIER_THRESHOLD=0.5

# --- Fallback Chain ---
# SHIELD_FALLBACK_PROVIDERS=ollama,openai,anthropic

# --- Shield Detection Thresholds ---
SHIELD_ML_HIGH=0.85
SHIELD_ML_LOW=0.30
SHIELD_RATE_LIMIT=30

# --- Anomaly Detection ML API ---
# ANOMALY_API_URL=http://localhost:8000
# ANOMALY_API_TIMEOUT=0.5

# --- Platform Security ---
# SENTINEL_API_KEY=
# CORS_ORIGINS=http://localhost:5000

# --- Server ---
# SENTINEL_HOST=0.0.0.0
# SENTINEL_PORT=5000
# SENTINEL_PRODUCTION=false
# SENTINEL_THREADS=4
# SENTINEL_BEHIND_PROXY=false

# --- CEF/SIEM Logging ---
# CEF_ENABLED=false
# CEF_OUTPUT=file
# CEF_FILE=sentinel_cef.log
# CEF_SYSLOG_HOST=
# CEF_SYSLOG_PORT=514
# CEF_SYSLOG_PROTOCOL=udp

# --- Session ---
# SHIELD_SESSION_TTL=3600
# SHIELD_SESSION_MAX=10000
# SHIELD_CLEANUP_INTERVAL=300
